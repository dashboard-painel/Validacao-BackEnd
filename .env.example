# Redshift Connection Configuration
# Copy this file to .env and fill in your actual values

REDSHIFT_HOST=your-cluster.region.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DATABASE=your_database
REDSHIFT_USER=your_username
REDSHIFT_PASSWORD=your_password
REDSHIFT_SCHEMA=public

# Local PostgreSQL (for storing comparison history)
LOCAL_DB_URL=postgresql://root:root@localhost:5432/valida

# CORS Configuration
# Use "*" to allow all origins or a comma-separated list of allowed origins
# Example: CORS_ORIGINS=http://localhost:3000,https://dashboard.example.com
CORS_ORIGINS=*
